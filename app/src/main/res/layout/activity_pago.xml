<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvTarjeta"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#009688"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvResultado">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etTitular"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_nombre"
                android:inputType="textPersonName"
                android:autofillHints="name"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:gravity="end|center_vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#000000" />

            <EditText
                android:id="@+id/etNumTarjeta"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_num_tarjeta"
                android:inputType="number"
                android:autofillHints="creditCardNumber"
                android:textColor="#FFFFFF"
                android:textColorHint="#FFFFFF"
                android:gravity="end|center_vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etMes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_mes"
                    android:inputType="number"
                    android:autofillHints="creditCardExpirationMonth"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FFFFFF"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etAnio"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_anio"
                    android:inputType="number"
                    android:autofillHints="creditCardExpirationYear"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FFFFFF"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etCVV"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_cvv"
                    android:inputType="numberPassword"
                    android:autofillHints="creditCardSecurityCode"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#FFFFFF"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/bPagar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/btn_pagar"
        android:backgroundTint="#6200EE"
        app:cornerRadius="0dp"
        app:layout_constraintTop_toBottomOf="@id/cvTarjeta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>